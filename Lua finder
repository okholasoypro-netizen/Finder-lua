-- Función para lanzar la notificación visual nativa en Roblox
local function alertaPantalla(titulo, texto)
    StarterGui:SetCore("SendNotification", {
        Title = titulo,
        Text = texto,
        Duration = 8,
        Button1 = "OK"
    })
end

-- Escáner Principal Inteligente
local function escanearServidor()
    local detectadosEnEsteTurno = 0
    
    print("\n==================================================")
    print("🔍 [DELTA ESCÁNER] ESCANEANDO EL 100% DE TU SERVIDOR...")
    print("==================================================")
    
    -- Recorremos Workspace buscando los Modelos de las bases
    for _, objeto in ipairs(workspace:GetDescendants()) do
        if objeto:IsA("Model") and not Players:GetPlayerFromCharacter(objeto) then
            local nombreModelo = string.lower(objeto.Name)
            
            -- Verificar contra la base de datos exacta de nombres
            for _, brainrotReal in ipairs(baseDatosBrainrots) do
                if string.find(nombreModelo, string.lower(brainrotReal)) then
                    detectadosEnEsteTurno = detectadosEnEsteTurno + 1
                    
                    -- Rastrear dinámicamente de quién es la base (Dueño)
                    local dueñoBase = "Mapa / Zona de Robo Neutral"
                    local ancestro = objeto.Parent
                    while ancestro and ancestro ~= workspace do
                        if Players:FindFirstChild(ancestro.Name) then
                            dueñoBase = ancestro.Name
                            break
                        elseif string.find(string.lower(ancestro.Name), "tycoon") or string.find(string.lower(ancestro.Name), "base") then
                            if ancestro:FindFirstChild("Owner") and ancestro.Owner.Value then
                                dueñoBase = tostring(ancestro.Owner.Value)
                            end
                            break
                        end
                        ancestro = ancestro.Parent
                    end
                    
                    -- Imprimir reporte detallado en la consola de Delta
                    print("» [CRITURA]: " .. brainrotReal .. " (Detectado como: " .. objeto.Name .. ")")
                    print("» [PROPIETARIO/BASE]: " .. dueñoBase)
                    print("» [CÓDIGO DE TELETRANSPORTE PARA AMIGOS]:")
                    print("game:GetService('TeleportService'):TeleportToPlaceInstance(" .. game.PlaceId .. ", '" .. game.JobId .. "', game.Players.LocalPlayer)")
                    print("--------------------------------------------------")
                    break -- Pasa al siguiente objeto una vez catalogado
                end
            end
        end
    end
    
    -- Reporte rápido en pantalla
    if detectadosEnEsteTurno > 0 then
        alertaPantalla("🚨 ¡Brainrots Ubicados!", "Se encontraron " .. detectadosEnEsteTurno .. " criaturas de la lista en las bases. ¡Abre los logs de Delta!")
    else
        print("[Escáner]: El servidor actual está limpio o solo tiene criaturas iniciales sin clasificar.")
    end
end

